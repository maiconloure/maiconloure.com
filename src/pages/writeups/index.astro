---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const entries = (await getCollection('writeups', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)
---

<BaseLayout title="Writeups" description="Security and engineering writeups by Maicon Lourenço.">
  <section class="container page">
    <p class="prompt eyebrow">ls writeups/</p>
    <h1>Writeups</h1>

    <ul class="writeup-list">
      {
        entries.map((entry) => (
          <li>
            <a href={`/writeups/${entry.id}`}>
              <h2>{entry.data.title}</h2>
              <p class="description">{entry.data.description}</p>
              <div class="meta">
                <time datetime={entry.data.pubDate.toISOString()}>
                  {entry.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
                {entry.data.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </a>
          </li>
        ))
      }
    </ul>

    {entries.length === 0 && <p class="empty">No writeups yet.</p>}
  </section>
</BaseLayout>

<style>
  .page {
    padding-block: 4rem 5rem;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--fg-muted);
    margin-bottom: 0.75rem;
  }

  .writeup-list {
    margin-top: 2rem;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .writeup-list a {
    display: block;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    color: var(--fg);
  }

  .writeup-list a:hover {
    text-decoration: none;
    border-color: var(--accent);
  }

  .writeup-list h2 {
    font-size: 1.1rem;
  }

  .description {
    margin-top: 0.5rem;
    color: var(--fg-muted);
  }

  .meta {
    margin-top: 1rem;
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg-muted);
  }

  .tag {
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
  }

  .empty {
    margin-top: 2rem;
    color: var(--fg-muted);
  }
</style>
